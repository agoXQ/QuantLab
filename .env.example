# ============================================================
# QuantLab — Local Environment Variables
# ============================================================
# Copy to `.env` (which is gitignored) and fill in real values.
# Each microservice loads `.env` automatically via pkg/env at startup.
# ============================================================

# --- Tushare (Market Data Service) ---
# Register at https://tushare.pro and copy the token from your dashboard.
TUSHARE_TOKEN=

# --- Optional: provider routing override ---
# Set to "fake" to disable Tushare and use the in-memory provider.
# MARKET_PROVIDER_DRIVER=tushare
